# Force LF line endings for all text files (Linux containers need Unix endings)
* text=auto eol=lf

# Ensure shell scripts are always LF
*.sh text eol=lf
*.bash text eol=lf

# Ensure Python files are always LF
*.py text eol=lf

# Ensure config/data files are always LF
*.yaml text eol=lf
*.yml text eol=lf
*.json text eol=lf
*.conf text eol=lf
*.cfg text eol=lf
*.toml text eol=lf

# Dockerfile
dockerfile* text eol=lf
Dockerfile* text eol=lf

# Binary files - don't touch
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.woff binary
*.woff2 binary
*.ttf binary
*.eot binary
*.sqlite binary
